# Скопируйте в .env и заполните значения.

TELEGRAM_BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# В Docker по умолчанию указывает на сервис db из docker-compose
DATABASE_URL=postgresql+asyncpg://gymbot:gymbot@db:5432/gymbot

# Базовый URL вашего бэкенда (сервис с API)
EXTERNAL_API_BASE_URL=http://host.docker.internal:8080
# EXTERNAL_API_KEY=optional-bearer-token

# Локальный запуск без Docker — свой Postgres или тот же URL, если проброшен порт
# DATABASE_URL=postgresql+asyncpg://gymbot:gymbot@127.0.0.1:5432/gymbot

# pgAdmin: http://localhost:5050 (порт задаётся PGADMIN_PORT)
# Не используйте домены вроде .local / .test — pgAdmin отклонит email и контейнер будет перезапускаться.
# PGADMIN_PORT=5050
# PGADMIN_DEFAULT_EMAIL=admin@example.com
# PGADMIN_DEFAULT_PASSWORD=your-secure-password
#
# Сервер БД в pgAdmin подставляется из docker/pgadmin/servers.json и docker/pgadmin/pgpass
# (логин/пароль по умолчанию gymbot/gymbot). Если меняете POSTGRES_* — обновите оба файла.
